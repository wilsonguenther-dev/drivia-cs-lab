{
  "name": "drivia-cs-lab",
  "version": "0.1.0",
  "private": false,
  "description": "Drivia Computer Science Lab — undergrad to PhD. History · formal defs · proofs · animations · code · papers · mastery. The standard set by Formula Lab, raised 10x.",
  "type": "module",
  "license": "MIT",
  "author": "Wilson Guenther <wilson@drivia.consulting>",
  "scripts": {
    "predev": "rm -rf node_modules/.vite .astro",
    "dev": "astro dev --port 4324",
    "build": "astro build",
    "preview": "astro preview --host --port 4324",
    "start": "node ./dist/server/entry.mjs",
    "check": "astro check",
    "audit": "tsx scripts/audit-topics.ts",
    "smoke": "tsx scripts/smoke.ts",
    "predeploy": "npm run check && npm run build && npm run audit"
  },
  "dependencies": {
    "@astrojs/node": "^9.1.3",
    "@astrojs/react": "^4.4.2",
    "astro": "5.7.6",
    "canvas-confetti": "1.9.3",
    "katex": "0.16.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/canvas-confetti": "1.9.0",
    "@types/katex": "^0.16.8",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "playwright": "^1.60.0",
    "tsx": "4.19.2",
    "typescript": "^5.9.3"
  }
}
