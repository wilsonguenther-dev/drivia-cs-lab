---
import "katex/dist/katex.min.css";
import "../styles/global.css";
import TTSSettings from "./TTSSettings.astro";
interface Props { title?: string; }
const { title = "Drivia CS Lab" } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#03030f">
  <meta name="referrer" content="no-referrer">
  <title>{title}</title>
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%2303030f'/%3E%3Ccircle cx='16' cy='16' r='8' fill='%2300d4ff'/%3E%3C/svg%3E">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="preconnect" href="https://i.ytimg.com">
</head>
<body>
  <div id="grain"></div>
  <slot />
  <slot name="overlays" />
  <TTSSettings />
</body>
</html>
