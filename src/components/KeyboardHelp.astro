<div id="kbd-overlay">
  <div class="kbd-card">
    <h3>⌨ Keyboard Shortcuts</h3>
    <div class="kbd-row"><div class="desc">Jump to chapter N</div><div class="keys"><kbd>1</kbd>—<kbd>9</kbd></div></div>
    <div class="kbd-row"><div class="desc">Hear pronunciation of nearest chapter</div><div class="keys"><kbd>H</kbd></div></div>
    <div class="kbd-row"><div class="desc">Toggle record</div><div class="keys"><kbd>R</kbd></div></div>
    <div class="kbd-row"><div class="desc">Animate formula breakdown</div><div class="keys"><kbd>A</kbd></div></div>
    <div class="kbd-row"><div class="desc">Focus typing on nearest chapter</div><div class="keys"><kbd>T</kbd></div></div>
    <div class="kbd-row"><div class="desc">Typing: auto-indent / skip to end of line</div><div class="keys"><kbd>Tab</kbd></div></div>
    <div class="kbd-row"><div class="desc">Typing: newline + auto-indent next line</div><div class="keys"><kbd>Enter</kbd></div></div>
    <div class="kbd-row"><div class="desc">Reset current chapter typing</div><div class="keys"><kbd>Esc</kbd> <kbd>Esc</kbd></div></div>
    <div class="kbd-row"><div class="desc">Toggle this overlay</div><div class="keys"><kbd>?</kbd></div></div>
    <button class="kbd-close" id="kbd-close">Close</button>
  </div>
</div>
