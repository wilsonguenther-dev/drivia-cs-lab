# Drivia CS Lab — environment variables
#
# Everything below is OPTIONAL. The lab works with zero environment setup
# because the default TTS backend is the browser's built-in Web Speech API.
# Configure these only if you want a specific TTS backend.

# ── Gemini Charon (baked WAVs) ────────────────────────────────────────────
# Required only at bake time (`npm run bake`) — NOT at runtime.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
